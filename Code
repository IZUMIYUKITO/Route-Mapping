def FIT(ind,F1,F2,F3,F4,F5):
    y=0.2402*((fee_cost(ind.matrix)-min(F1))/(max(F1)-min(F1)))**2+0.2334*((time_cost(ind.matrix)-min(F2))/(max(F2)-min(F2)))**2+0.1296*((load(ind.matrix)-min(F3))/(max(F3)-min(F3)))**2+0.1464*((utilization_rate(ind.matrix)-min(F4))/(max(F4)-min(F4)))**2+0.2503*((finance(ind.matrix)-min(F5))/(max(F5)-min(F5)))**2
    return 1/y

def genetic_algorithm():
    population=initialize_population()
    for individual in population:
        individual._init_()
    X=[]
    Y=[]
    Z=[]
    for gen in range(GENERATIONS):
        F1=[]
        F2=[]
        F3=[]
        F4=[]
        F5=[]
        for i in range(POPULATION_SIZE):
            F1.append(fee_cost(population[i].matrix))
            F2.append(time_cost(population[i].matrix))
            F3.append(load(population[i].matrix))
            F4.append(utilization_rate(population[i].matrix))
            F5.append(finance(population[i].matrix))
        population.sort(key=lambda x:FIT(x,F1,F2,F3,F4,F5),reverse=True)
        X.append(gen)
        Y.append(FIT(population[0], F1, F2, F3, F4, F5))
        Z.append(population[0])
        print(f"Generation {gen}:Best Fitness={FIT(population[0],F1,F2,F3,F4,F5):.2f}")

        new_population=[]
        new_population.extend(population[:10])
        while len(new_population)<POPULATION_SIZE:
            parents=select_parents(population,F1,F2,F3,F4,F5)

            offspring1,offspring2=crossover(parents[0],parents[1],population,F1,F2,F3,F4,F5)

            offspring1=mutate(offspring1,gen)
            offspring2=mutate(offspring2,gen)

            new_population.append(offspring1)            
            new_population.append(offspring2)  
        population=new_population[:POPULATION_SIZE]
        for i in range(POPULATION_SIZE):
            population[i]=repair_individual2(population[i])
        
    return population[0],F1,F2,F3,F4,F5,X,Y

